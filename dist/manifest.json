{
  "manifest_version": 3,
  "name": "On a second thought…",
  "version": "1.0.0",
  "description": "A gentle pause between wanting and paying. Breathe, see the price in hours of your life, then decide. Fully on device.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "alarms"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-04MrVdQ-.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "On a second thought…, almost bought it",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "src/options/index.html",
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/personalUnits-qqcaQPHO.js",
        "assets/taxEngine-CYtU0DVd.js",
        "assets/parkingLot-C-Q_MqRQ.js",
        "assets/categories-CCmypuoU.js",
        "assets/index.ts-Bawi4LRQ.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
